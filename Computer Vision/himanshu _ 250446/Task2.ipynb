import cv2
import numpy as np
from IPython.display import Video

cap = cv2.VideoCapture('/content/WhatsApp Video 2026-04-10 at 10.14.23 PM.mp4')

fourcc = cv2.VideoWriter_fourcc(*'mp4v')
out = cv2.VideoWriter('output.mp4', fourcc, 20.0,
                      (int(540*0.9), int(380*0.7)))

while cap.isOpened():

    ret, frame = cap.read()
    if not ret:
        break

    frame = cv2.resize(frame, (540, 380), interpolation=cv2.INTER_CUBIC)

    height, width = frame.shape[:2]


    frame = frame[0:int(height*0.7), :]

    frame = frame[:, int(width*0.1):]

    hsv = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)

    lower_red1 = np.array([0, 100, 100])
    upper_red1 = np.array([10, 255, 255])

    lower_red2 = np.array([160, 100, 100])
    upper_red2 = np.array([179, 255, 255])

    mask = cv2.inRange(hsv, lower_red1, upper_red1) + \
           cv2.inRange(hsv, lower_red2, upper_red2)

    contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

    if len(contours) > 0:
        c = max(contours, key=cv2.contourArea)

        (x, y), radius = cv2.minEnclosingCircle(c)

        if radius > 5:
            center = (int(x), int(y))
            radius = int(radius)

            cv2.circle(frame, center, radius, (0, 255, 0), 2)
            cv2.circle(frame, center, 5, (255, 0, 0), -1)

    out.write(frame)

cap.release()
out.release()
